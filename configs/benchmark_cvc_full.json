{
  "payoff_mode": "binary",
  "backends": [
    "cvc_local"
  ],
  "agents": [
    {
      "name": "teammate_reliability",
      "backend": "cvc_local",
      "kind": "policy_spec",
      "policy_spec": "class=benchmarks.cvc.policy.TeammateReliabilityPolicy"
    },
    {
      "name": "starter",
      "backend": "cvc_local",
      "kind": "policy_spec",
      "policy_spec": "class=cogames.policy.starter_agent.StarterPolicy"
    },
    {
      "name": "miner",
      "backend": "cvc_local",
      "kind": "policy_spec",
      "policy_spec": "class=cogames.policy.role_policies.MinerRolePolicy"
    },
    {
      "name": "aligner",
      "backend": "cvc_local",
      "kind": "policy_spec",
      "policy_spec": "class=cogames.policy.role_policies.AlignerRolePolicy"
    },
    {
      "name": "scrambler",
      "backend": "cvc_local",
      "kind": "policy_spec",
      "policy_spec": "class=cogames.policy.role_policies.ScramblerRolePolicy"
    },
    {
      "name": "scout",
      "backend": "cvc_local",
      "kind": "policy_spec",
      "policy_spec": "class=cogames.policy.role_policies.ScoutRolePolicy"
    }
  ],
  "num_replications": 10,
  "num_rounds": 100,
  "output_dir": "results/benchmark_cvc_full",
  "random_seed": 42,
  "backend_configs": {
    "cvc_local": {
      "mission": "machina_1",
      "num_agents": 8,
      "max_steps": 10000,
      "python_bin": "python3.12"
    }
  }
}
