% flip to true and set \anonsupprepourl once an anonymized supplementary repo is live
\newif\ifanonsupprepo
\anonsupprepofalse
\newcommand{\anonsupprepourl}{}
\newcommand{\codereleasestatement}{%
  \ifanonsupprepo
    Simulation code, analysis scripts, and experiment configurations are provided in an anonymized supplementary repository: \url{\anonsupprepourl}.
  \else
    Simulation code, analysis scripts, and experiment configurations will be released in a public repository upon acceptance.
  \fi
}
\newcommand{\codereleaseartifactlist}{the simulation environments, precision-runtime variants, experiment configuration files, analysis scripts, and figure-generation code used for the reported experiments}
