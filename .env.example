# Cloud provider: gcp or oracle
CLOUD_PROVIDER=oracle
CLOUD_AVAILABLE_PROVIDERS="gcp oracle"

# Common
VM_REPO_PATH='~/affect_aif'

# GCP (only if CLOUD_PROVIDER=gcp)
GCP_PROJECT_ID=
GCP_ZONE=us-west1-a
GCP_VM_NAME=affect-aif-vm
GCP_MACHINE_TYPE=c3-standard-16
GCP_DISK_SIZE=50
GCP_IMAGE_FAMILY=ubuntu-2404-lts-amd64
GCP_IMAGE_PROJECT=ubuntu-os-cloud
GCP_CONDA_ENV=affect_aif

# Oracle (only if CLOUD_PROVIDER=oracle)
# Add extra target names to ORACLE_AVAILABLE_TARGETS and define matching
# ORACLE_<TARGET>_{HOST,USER,SSH_KEY,REPO_PATH,CONDA_ENV} values for each VM.
ORACLE_TARGET=paid
ORACLE_AVAILABLE_TARGETS="paid free"

# Oracle paid target
ORACLE_PAID_HOST=
ORACLE_PAID_USER=ubuntu
ORACLE_PAID_SSH_KEY=~/.ssh/oracle_paid_key
ORACLE_PAID_REPO_PATH='~/affect_aif'
ORACLE_PAID_CONDA_ENV=affect_aif

# Oracle always free target
ORACLE_FREE_HOST=
ORACLE_FREE_USER=ubuntu
ORACLE_FREE_SSH_KEY=~/.ssh/oracle_free_key
ORACLE_FREE_REPO_PATH='~/affect_aif'
ORACLE_FREE_CONDA_ENV=affect_aif
